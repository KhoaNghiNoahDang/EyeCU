				{
					"name": "Patient Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Token and Patient ID obtained\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property(\"access_token\");",
									"    pm.environment.set(\"patient_token\", jsonData.access_token);",
									"    ",
									"    // Decode JWT in sandbox to extract patient UUID",
									"    var token = jsonData.access_token;",
									"    var base64Url = token.split('.')[1];",
									"    var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');",
									"    var jsonPayload = decodeURIComponent(atob(base64).split('').map(function(c) {",
									"        return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);",
									"    }).join(''));",
									"    var payload = JSON.parse(jsonPayload);",
									"    pm.environment.set(\"patient_id\", payload.sub);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
