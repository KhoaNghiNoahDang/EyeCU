{
  "info": {
    "_postman_id": "08fbdc84-d3c8-4147-83b6-075f0e741afe",
    "name": "EyeCU_Internal_API_Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "56273424",
