# Dockerfile dành cho chạy dev (hot-reload, dùng để test nhanh)
FROM node:22-alpine

WORKDIR /app

# Cài dependencies
COPY package.json package-lock.json ./
RUN npm ci --prefer-offline

# Copy source code
COPY . .

# Vite dev server expose port 5173
EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--port", "5173"]


