# Dockerfile dành cho chạy dev (hot-reload, dùng để test nhanh)
FROM node:20-alpine

WORKDIR /app

# Cài dependencies
COPY package.json package-lock.json ./
RUN npm ci --prefer-offline

# Copy source code
COPY . .

# Vite dev server expose port 5173
EXPOSE 5173

# Chạy dev server, bind tất cả interface để Docker port-forward được
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
